# Enable gzip compression for API responses
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/json application/javascript text/html text/plain text/css
</IfModule>

# Protect sensitive files from direct web access
<FilesMatch "^(config|env|\.env)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

<Files "*.php">
    Order allow,deny
    Allow from all
</Files>

# Block direct access to SQL migration files — schema must not be public
<FilesMatch "\.sql$">
    Order allow,deny
    Deny from all
</FilesMatch>
